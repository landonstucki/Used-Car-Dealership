<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="account-dashboard">
  <section class="account-dashboard__header">
    <h1>Account Dashboard</h1>

    <p>
      Welcome,
      <strong><%= currentUser ? currentUser.name : 'User' %></strong>
    </p>
  </section>

  <section class="account-dashboard__info">
    <div class="dashboard-card">
      <h2>Your Info</h2>

      <p><strong>Name:</strong> <%= currentUser ? currentUser.name : 'N/A' %></p>
      <p><strong>Email:</strong> <%= currentUser ? currentUser.email : 'N/A' %></p>
      <p><strong>Role:</strong> <%= currentUser ? currentUser.role : 'N/A' %></p>
    </div>
  </section>

  <section class="account-dashboard__actions">
    <a href="/vehicles" class="dashboard-card">
      <h2>Browse Vehicles</h2>
      <p>View available inventory.</p>
    </a>

      <a href="/account/service-requests" class="dashboard-card">
        <h2>My Service Requests</h2>
        <p>View and track your service requests.</p>
      </a>

    <form method="POST" action="/logout">
      <button type="submit">Logout</button>
    </form>
  </section>
</main>

<%- include('../partials/footer') %>